<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step1"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step1_desc"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/battOptButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_batt_btn"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/battStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:layout_marginTop="4dp"
            tools:text="@string/setup_batt_pending"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step2"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step2_desc"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/pasteUrlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_paste_btn"
            android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/setup_url_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/urlField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/setup_token_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tokenField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_save_btn"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
