<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      G2CC — Display Renderer Test Harness.
      Standalone BLE connect + auth + render to the G2 glasses, driven by buttons + a Diag
      checkbox. The connection loop runs in a FOREGROUND SERVICE (ConnectionService) so it
      survives the harness being backgrounded/pocketed — auth token + Tailscale server are
      baked in via BuildConfig.
    -->

    <!-- BLE: connect to + scan for the lens pair. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <!-- BLE scanning on API < 31 requires location. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Network: stream the diagnostics log to the server. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service: keep the BLE connection loop alive when the harness isn't
         foregrounded (pocket / screen-off / SSH-terminal app) — the recovery fix. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- PARTIAL_WAKE_LOCK so the keepalive/sync/watchdog delay() loops aren't Doze-throttled
         (FG type stops process-kill, NOT CPU throttling — factory finding). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- API 33+: the FG-service notification + the battery-opt re-grant prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Battery-opt exemption: without it Doze kills even the FG service. Sideloaded app. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:name=".G2CCApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.G2CC"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- The harness IS the app — the only launcher activity. -->
        <activity
            android:name=".harness.HarnessActivity"
            android:exported="true"
            android:label="G2CC Harness">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Owns the BLE connection loop (scan/auth/keepalive/sync/watchdog/renewal/render/
             auto-recovery); survives the Activity being backgrounded or destroyed. -->
        <service
            android:name=".service.ConnectionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />
    </application>
</manifest>
