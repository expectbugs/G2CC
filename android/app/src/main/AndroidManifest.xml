<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      G2CC — Display Renderer Test Harness.
      Standalone BLE connect + auth + render to the G2 glasses, driven by buttons + a Diag
      checkbox. The connection loop runs in a FOREGROUND SERVICE (ConnectionService) so it
      survives the harness being backgrounded/pocketed — auth token + Tailscale server are
      baked in via BuildConfig.
    -->

    <!-- BLE: connect to + scan for the lens pair. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <!-- BLE scanning on API < 31 requires location. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!-- Network: stream the diagnostics log to the server. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service: keep the BLE connection loop alive when the harness isn't
         foregrounded (pocket / screen-off / SSH-terminal app) — the recovery fix. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- DE dictation (server audio_request → phone mic → STT). The mic FGS type must be in
         the service's type mask from the start (Android 14+; can't upgrade mid-flight). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- PARTIAL_WAKE_LOCK so the keepalive/sync/watchdog delay() loops aren't Doze-throttled
         (FG type stops process-kill, NOT CPU throttling — factory finding). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- API 33+: the FG-service notification + the battery-opt re-grant prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Battery-opt exemption: without it Doze kills even the FG service. Sideloaded app. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Boot auto-start (the all-day bridge must survive a reboot — review 2026-06-11b). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Phase 4b SMS window: read threads + resolve contact names + send replies.
         One-time home grants (prime-directive-compatible, like the NLS grant). -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:name=".G2CCApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.G2CC"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- The harness IS the app — the only launcher activity. -->
        <activity
            android:name=".harness.HarnessActivity"
            android:exported="true"
            android:label="G2CC Harness">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phone control mode (multi-surface 2026-07-13): landscape-fullscreen
             mirror + touch/keyboard input surface. Launched from the harness'
             "Phone Control" button only — not exported. Locked landscape: the
             576×288 (2:1) mirror is the whole point of the screen. -->
        <activity
            android:name=".harness.ControlActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:label="G2CC Control" />

        <!-- Owns the BLE connection loop (scan/auth/keepalive/sync/watchdog/renewal/render/
             auto-recovery); survives the Activity being backgrounded or destroyed. -->
        <service
            android:name=".service.ConnectionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice|microphone" />

        <!-- Phase 9: phone-notification mirror (READ-ONLY). The SYSTEM binds this
             (BIND_NOTIFICATION_LISTENER_SERVICE keeps everyone else out); needs the
             one-time "Notification access" grant — HarnessActivity has the row +
             deep link. NO declarative 'ongoing' filter (review 2026-06-11b): an
             incoming call's CallStyle notification IS ongoing — the filter meant
             the dialer→'call' popup could never fire for a live call. Ongoing
             non-call notifications are dropped in forward() instead. -->
        <service
            android:name=".service.NotifyListener"
            android:exported="false"
            android:label="G2CC glasses mirror"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Boot/update auto-start (review 2026-06-11b: the receiver had fallen out
             of the manifest with the parked G2CCService — after ANY reboot the
             bridge stayed down until Adam opened the app, and "system reboot" is a
             required reconnect scenario). connectedDevice-type FGS is allowed from
             BOOT_COMPLETED; the mic type is re-granted on next app-open (the
             existing micFgsGranted retry). -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Tasker / adb broadcast surface (android/INTENTS.md). Re-registered in
             v1.7 (it had silently fallen out of the manifest with the parked
             G2CCService); deliberately open — see INTENTS.md §Security. -->
        <receiver
            android:name=".intents.IntentReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.g2cc.intent.action.PING" />
                <action android:name="com.g2cc.intent.action.START_RECORDING" />
                <action android:name="com.g2cc.intent.action.STOP_RECORDING" />
                <action android:name="com.g2cc.intent.action.SHOW_DIRECTORY_PICKER" />
                <action android:name="com.g2cc.intent.action.SWITCH_DISPATCH_TARGET" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
